{
	"name": "upstride-backend",
	"version": "1.0.0",
	"description": "",
	"type": "commonjs",
	"main": "src/main/index.js",
	"scripts": {
		"start": "node dist/main/index.js",
		"dev": "nodemon --watch src --ignore dist --ignore logs -e ts --exec 'tsc  && node --env-file=.env  dist/main/index.js'",
		"build": "tsc",
		"prepare": "husky",
		"format": "biome format --write",
		"type-check": "tsc --noEmit",
		"lint-format": "biome check --write",
		"test": "vitest",
		"seed:interests": "npx tsx --env-file=.env scripts/seed-interests.ts",
		"seed:professions": "npx tsx --env-file=.env scripts/seed-professions.ts",
		"seed:skills": "npx tsx --env-file=.env scripts/seed-skills.ts",
		"seed:superadmin": "npx tsx --env-file=.env scripts/seed-superadmin.ts",
		"seed:users": "npx tsx --env-file=.env scripts/seed-users.ts",
		"seed:platform-transactions": "npx tsx --env-file=.env scripts/generate-platform-transactions.ts",
		"fix:payment-transaction-indexes": "npx tsx --env-file=.env scripts/fix-payment-transaction-indexes.ts",
		"seed": "npm run seed:interests && npm run seed:professions && npm run seed:skills"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"packageManager": "pnpm@10.28.2",
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1001.0",
		"@aws-sdk/s3-presigned-post": "^3.1003.0",
		"@aws-sdk/s3-request-presigner": "^3.1001.0",
		"@types/nodemailer": "^7.0.11",
		"argon2": "^0.44.0",
		"bullmq": "^5.70.1",
		"compression": "^1.8.1",
		"cookie-parser": "^1.4.7",
		"cors": "^2.8.6",
		"csrf-csrf": "^4.0.3",
		"express": "^5.2.1",
		"express-rate-limit": "^8.2.1",
		"helmet": "^8.1.0",
		"inversify": "^7.11.0",
		"ioredis": "^5.9.3",
		"jsonwebtoken": "^9.0.3",
		"mongoose": "^9.2.3",
		"nodemailer": "^8.0.1",
		"pino": "^10.3.1",
		"pino-loki": "^3.0.0",
		"pino-pretty": "^13.1.3",
		"rate-limit-redis": "^4.3.1",
		"reflect-metadata": "^0.2.2",
		"slugify": "^1.6.8",
		"socket.io": "^4.8.3",
		"stripe": "^20.4.1",
		"ua-parser-js": "^2.0.9",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.4",
		"@faker-js/faker": "10.3.0",
		"@types/compression": "^1.8.1",
		"@types/cookie-parser": "^1.4.10",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^25.3.0",
		"@types/ua-parser-js": "^0.7.39",
		"@vitest/expect": "^4.0.18",
		"husky": "^9.1.7",
		"nodemon": "^3.1.14",
		"tsc-alias": "^1.8.16",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	}
}
